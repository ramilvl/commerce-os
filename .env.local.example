# CommerceOS runs fully in demo mode with no environment variables set,
# using the seeded mock data layer in src/lib/mock/.
#
# To connect a real Supabase project instead, copy this file to .env.local
# and fill in your project's values from https://app.supabase.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
